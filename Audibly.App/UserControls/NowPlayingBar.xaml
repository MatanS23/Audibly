<?xml version="1.0" encoding="utf-8" ?>

<UserControl
    mc:Ignorable="d"
    x:Class="Audibly.App.UserControls.NowPlayingBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="using:Audibly.App.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <converters:ProgressSliderValueConverter x:Key="ProgressSliderValueConverter" />
    </UserControl.Resources>

    <!--  now playing bar  -->
    <Grid
        ColumnSpacing="15"
        HorizontalAlignment="Stretch"
        x:Name="NowPlayingBarGrid">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  row 0: chapter progress  -->
        <TextBlock
            FontSize="20"
            Grid.Column="0"
            Grid.Row="0"
            HorizontalAlignment="Center"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{x:Bind PlayerViewModel.ChapterPositionText, Mode=OneWay}"
            VerticalAlignment="Bottom"
            x:Name="CurrentTimeTextBlock" />

        <Slider
            Grid.Column="1"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            Margin="0,0,0,-4"
            Maximum="{x:Bind PlayerViewModel.ChapterDurationMs, Mode=OneWay}"
            ValueChanged="Slider_OnValueChanged"
            ThumbToolTipValueConverter="{StaticResource ProgressSliderValueConverter}"
            Value="{x:Bind PlayerViewModel.ChapterPositionMs, Mode=OneWay}"
            VerticalAlignment="Bottom"
            x:Name="ProgressSlider" />

        <!--  chapter time toggle button: tapping cycles between total duration and time remaining  -->
        <Button
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0"
            Click="ChapterTimeButton_Click"
            Grid.Column="2"
            Grid.Row="0"
            HorizontalAlignment="Center"
            Padding="0"
            VerticalAlignment="Bottom"
            x:Name="ChapterTimeButton">
            <TextBlock
                FontSize="20"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind PlayerViewModel.ChapterTimeDisplayText, Mode=OneWay}" />
        </Button>

        <!--  row 1: book-level progress  -->
        <TextBlock
            FontSize="12"
            Grid.Column="0"
            Grid.Row="1"
            HorizontalAlignment="Center"
            Margin="0,4,0,0"
            Opacity="0.6"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{x:Bind PlayerViewModel.BookElapsedText, Mode=OneWay}"
            VerticalAlignment="Top" />

        <TextBlock
            FontSize="12"
            Grid.Column="1"
            Grid.Row="1"
            HorizontalAlignment="Center"
            Margin="0,4,0,0"
            Opacity="0.6"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="Book Progress"
            VerticalAlignment="Top" />

        <TextBlock
            FontSize="12"
            Grid.Column="2"
            Grid.Row="1"
            HorizontalAlignment="Center"
            Margin="0,4,0,0"
            Opacity="0.6"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{x:Bind PlayerViewModel.BookRemainingText, Mode=OneWay}"
            VerticalAlignment="Top" />

    </Grid>
</UserControl>